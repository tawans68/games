<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Home Screen -->
    <LinearLayout
        android:id="@+id/homeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_title"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:id="@+id/tvLatestScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/latest_score"
            android:textSize="20sp"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:id="@+id/tvHighScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/high_score"
            android:textSize="20sp"
            android:textColor="#FF9800"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnLanguage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language_toggle"
            android:layout_marginBottom="20dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnComputerTerms"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="@string/btn_computer_terms"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#673AB7"/>

        <Button
            android:id="@+id/btnPractice"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="@string/btn_practice"
            android:textSize="18sp"
            android:backgroundTint="#009688"/>

        <TextView
            android:id="@+id/tvLoadStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="กำลังโหลด..."
            android:layout_marginTop="20dp"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Category Selection Screen -->
    <LinearLayout
        android:id="@+id/categoryContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_category_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:id="@+id/categoryList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <!-- Buttons will be added here dynamically -->
            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnBackFromCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_cancel"
            android:layout_marginTop="10dp"
            android:backgroundTint="#9E9E9E"/>
    </LinearLayout>

    <!-- Mode Description Screen -->
    <LinearLayout
        android:id="@+id/descContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvDescTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="หัวข้อโหมด"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvDescBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="รายละเอียดวิธีการเล่น..."
            android:textSize="18sp"
            android:textAlignment="center"
            android:layout_marginBottom="40dp"
            android:lineSpacingExtra="8dp"/>

        <Button
            android:id="@+id/btnConfirmStart"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="@string/btn_confirm_start"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#4CAF50"/>

        <Button
            android:id="@+id/btnCancelDesc"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="@string/btn_cancel"
            android:textSize="18sp"
            android:backgroundTint="#9E9E9E"/>
    </LinearLayout>

    <!-- Game Screen -->
    <ScrollView
        android:id="@+id/gameContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvLetters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_letters"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#FF0000"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/input_hint"
                android:autofillHints="none"
                android:inputType="text"
                android:textAlignment="center"
                android:textSize="20sp"/>

            <Button
                android:id="@+id/btnCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_check"
                android:layout_marginTop="10dp"
                android:backgroundTint="#4CAF50"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tv_timer"
                    android:textSize="18sp"
                    android:textAlignment="center"
                    android:layout_marginBottom="5dp"/>

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tv_score"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="30dp"/>

            <Button
                android:id="@+id/btnBackToHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_back_to_home"
                android:layout_marginTop="20dp"
                android:backgroundTint="#9E9E9E"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnRestart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_new"
                android:layout_marginTop="10dp"
                android:backgroundTint="#4CAF50"
                android:visibility="gone"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp">

                <Button
                    android:id="@+id/btnClose"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="X"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#F44336"
                    android:padding="0dp"
                    android:layout_alignParentEnd="true"
                    android:gravity="center"/>
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
